# Sync a single skill from canonical store to .agents/skills/ and .claude/skills/
# Reads from .afx/skills/{category}/{name}/ and copies to both targets
skill_sync() {
    local skill_name="$1"
    local category="$2"
    local item_type="$3"
    local canonical_dir="$TARGET_DIR/.afx/skills/$category/$skill_name"

    [[ -d "$canonical_dir" ]] || return 0

    # Build target list based on agent selection
    local targets=()
    [[ "$NO_CLAUDE_MD" != "true" ]] && targets+=(".claude/skills")
    [[ "$NO_AGENTS_MD" != "true" ]] && targets+=(".agents/skills")
    [[ ${#targets[@]} -eq 0 ]] && return 0

    local target_labels=""
    for target in "${targets[@]}"; do
        local target_dir="$TARGET_DIR/$target/$skill_name"
        if [[ "$DRY_RUN" == "true" ]]; then
            INSTALLED+=("  → $target/$skill_name (would create)")
        else
            mkdir -p "$target_dir"
            if [[ "$item_type" == "afx" && -f "$canonical_dir/SKILL.md" ]]; then
                # Strip provider-command markers from SKILL.md
                sed \
                    -e '/<!-- @afx:provider-commands -->/d' \
                    -e '/<!-- @afx:\/provider-commands -->/d' \
                    "$canonical_dir/SKILL.md" > "$target_dir/SKILL.md"
                # Copy references/ if present
                [[ -d "$canonical_dir/references" ]] && cp -r "$canonical_dir/references" "$target_dir/"
            else
                cp -r "$canonical_dir"/. "$target_dir/"
            fi
        fi
        [[ -n "$target_labels" ]] && target_labels+=" + "
        target_labels+="$target/$skill_name"
    done
    INSTALLED+=("  → $target_labels")
}

# Sync all skills from a pack to .agents/skills/ and .claude/skills/
pack_sync() {
    local pack_name="$1"
    local category
    category=$(category_from_pack "$pack_name")
    local skills_dir="$TARGET_DIR/.afx/skills/$category"

    [[ -d "$skills_dir" ]] || return 0

    for skill_dir in "$skills_dir"/*/; do
        [[ -d "$skill_dir" ]] || continue
        local name=$(basename "$skill_dir")
        local item_type
        if [[ -f "$skill_dir/.claude-plugin/plugin.json" ]]; then
            item_type="plugin"
        else
            item_type="afx"
        fi
        skill_sync "$name" "$category" "$item_type"
    done
}

# Remove all skill copies from .agents/skills/ and .claude/skills/ for a given pack
pack_remove_from_agents() {
    local pack_name="$1"

    if [[ "$DRY_RUN" == "true" ]]; then
        echo -e "  ${CYAN}(would remove skill copies for $pack_name)${NC}"
        return 0
    fi

    # Read skill names from .afx.yaml for this pack
    while IFS=: read -r name category; do
        [[ -z "$name" ]] && continue
        rm -rf "$TARGET_DIR/.agents/skills/$name"
        rm -rf "$TARGET_DIR/.claude/skills/$name"
    done < <(afx_yaml_skills_for_pack "$pack_name")
}

normalize_pack_name() {
    local input="$1"
    if [[ "$input" == afx-pack-* ]]; then
        echo "$input"
    else
        echo "afx-pack-$input"
    fi
}

# Install a pack: fetch manifest → download → detect → route → copy → state
pack_install() {
    local input_name="$1"
    local ref_override="${2:-}"
    local pack_name
    pack_name=$(normalize_pack_name "$input_name")
    local ref
    if [[ -n "$ref_override" ]]; then
        ref="$ref_override"
    else
        ref=$(resolve_ref) || exit 1
    fi
    local pack_dir="$TARGET_DIR/.afx/packs/$pack_name"

    echo -e "${BLUE}Installing pack '$pack_name' (ref: $ref)...${NC}"

    if [[ "$DRY_RUN" != "true" ]]; then
        mkdir -p "$TARGET_DIR/.afx/.cache"
    fi
    ensure_gitignore ".afx/"

    local category
    category=$(category_from_pack "$pack_name")

    # ── Local source path (--source) ──────────────────────────────────────
    if [[ -n "$SOURCE_DIR" ]]; then
        local local_skills_dir="$SOURCE_DIR/skills/$category"
        if [[ ! -d "$local_skills_dir" ]]; then
            echo -e "${RED}Error: Category '$category' not found in source: $local_skills_dir${NC}"
            return 1
        fi

        echo -e "  ${CYAN}Reading from local source: $local_skills_dir${NC}"

        for item_dir in "$local_skills_dir"/*/; do
            [[ -d "$item_dir" ]] || continue
            local item_name=$(basename "$item_dir")

            local type
            type=$(detect_type "$item_dir" "${AFX_REPO}")
            echo -e "  ${GREEN}Found: $item_name (type: $type)${NC}"

            if [[ "$DRY_RUN" != "true" ]]; then
                route_item "$item_dir" "$item_name" "$type" "$category"
                afx_yaml_add_skill "$item_name" "$category" "$pack_name" "$type"
                skill_sync "$item_name" "$category" "$type"
            else
                INSTALLED+=("  ↓ $item_name ($type)")
            fi
        done

        afx_yaml_set_pack "$pack_name" "$ref"
        echo -e "${GREEN}Pack '$pack_name' installed from local source.${NC}"
        return
    fi

    # ── Remote path (default) ─────────────────────────────────────────────
    local manifest
    manifest=$(fetch_manifest "$pack_name" "$ref") || exit 1

    while IFS= read -r include_line; do
        [[ -z "$include_line" ]] && continue

        local repo path
        repo=$(echo "$include_line" | awk '{print $1}')
        path=$(echo "$include_line" | awk '{print $2}')
        local items_str
        items_str=$(echo "$include_line" | cut -d' ' -f3-)

        local item_ref="main"
        if [[ "$repo" == "${AFX_REPO}" ]]; then
            item_ref="$ref"
        fi

        echo -e "  ${CYAN}Downloading from ${repo} (ref: ${item_ref})...${NC}"

        local temp
        temp=$(download_items "$repo" "$item_ref" "$path" $items_str)

        for item_name in $items_str; do
            local item_dir="$temp/${path}${item_name}"
            if [[ ! -d "$item_dir" ]]; then
                echo -e "  ${YELLOW}Warning: '$item_name' not found in download — skipping${NC}"
                continue
            fi

            local type
            type=$(detect_type "$item_dir" "$repo")
            echo -e "  ${GREEN}Found: $item_name (type: $type)${NC}"

            if [[ "$DRY_RUN" != "true" ]]; then
                route_item "$item_dir" "$item_name" "$type" "$category"
                afx_yaml_add_skill "$item_name" "$category" "$pack_name" "$type"
                skill_sync "$item_name" "$category" "$type"
            else
                INSTALLED+=("  ↓ $item_name ($type)")
            fi
        done

        rm -rf "$temp"
    done < <(for_each_include "$manifest")

    afx_yaml_set_pack "$pack_name" "$ref"
    rm -f "$manifest"

    echo -e "${GREEN}Pack '$pack_name' installed (ref: $ref).${NC}"
    echo ""
}

pack_remove() {
    local input_name="$1"
    local pack_name
    pack_name=$(normalize_pack_name "$input_name")
    local category
    category=$(category_from_pack "$pack_name")

    # Remove skill copies from .agents/skills/
    pack_remove_from_agents "$pack_name"

    # Remove canonical skills
    if [[ "$DRY_RUN" != "true" ]]; then
        while IFS=: read -r name cat; do
            [[ -z "$name" ]] && continue
            rm -rf "$TARGET_DIR/.afx/skills/$cat/$name"
            afx_yaml_remove_skill "$name"
        done < <(afx_yaml_skills_for_pack "$pack_name")

        # Clean up empty category dir
        [[ -d "$TARGET_DIR/.afx/skills/$category" ]] && \
            rmdir "$TARGET_DIR/.afx/skills/$category" 2>/dev/null || true
    fi

    afx_yaml_remove_pack "$pack_name"
    echo -e "${YELLOW}Pack '$pack_name' removed entirely.${NC}"
}

# Toggle a skill on or off (enable/disable in .agents/skills/)
cmd_skill_toggle() {
    local skill_name="$1"
    local value="$2"   # "on" or "off"

    # Find skill's category and type from .afx.yaml
    local yaml="$TARGET_DIR/.afx.yaml"
    local category="" item_type="" in_skill=false
    while IFS= read -r line; do
        if [[ "$line" =~ ^\ \ -\ name:\ $skill_name$ ]]; then in_skill=true; continue; fi
        if $in_skill && [[ "$line" =~ ^\ \ -\ name: ]]; then break; fi
        if $in_skill && [[ "$line" =~ ^\ \ \ \ category:\ (.+) ]]; then category="${BASH_REMATCH[1]}"; fi
        if $in_skill && [[ "$line" =~ ^\ \ \ \ item_type:\ (.+) ]]; then item_type="${BASH_REMATCH[1]}"; fi
    done < "$yaml"

    if [[ -z "$category" ]]; then
        echo -e "${RED}Error: Skill '$skill_name' not found in .afx.yaml${NC}"
        exit 1
    fi

    if [[ "$value" == "on" ]]; then
        # Re-sync this skill to .agents/skills/
        skill_sync "$skill_name" "$category" "$item_type"
        echo -e "${GREEN}Skill '$skill_name' enabled.${NC}"
    else
        # Remove from .agents/skills/ and .claude/skills/
        if [[ "$DRY_RUN" != "true" ]]; then
            rm -rf "$TARGET_DIR/.agents/skills/$skill_name"
            rm -rf "$TARGET_DIR/.claude/skills/$skill_name"
        fi
        echo -e "${YELLOW}Skill '$skill_name' disabled.${NC}"
    fi
}

# Delete a custom skill entirely
cmd_skill_delete() {
    local skill_name="$1"

    # Remove from .agents/skills/, .claude/skills/, and canonical store
    if [[ "$DRY_RUN" != "true" ]]; then
        rm -rf "$TARGET_DIR/.agents/skills/$skill_name"
        rm -rf "$TARGET_DIR/.claude/skills/$skill_name"
        rm -rf "$TARGET_DIR/.afx/skills/custom/$skill_name"
    fi

    afx_yaml_remove_skill "$skill_name"
    echo -e "${YELLOW}Skill '$skill_name' deleted.${NC}"
}

pack_list() {
    local has_packs=false

    echo -e "${BLUE}Installed packs:${NC}"
    echo ""

    while IFS=: read -r name ref; do
        has_packs=true
        echo -e "  ${GREEN}●${NC} $name (ref: $ref)"

        # Show skills for this pack
        while IFS=: read -r skill_name category; do
            echo -e "    ${DIM}$skill_name${NC}"
        done < <(afx_yaml_skills_for_pack "$name")
    done < <(afx_yaml_all_packs)

    if [[ "$has_packs" == "false" ]]; then
        echo "  (none)"
        echo ""
        echo "Install a pack:"
        echo "  ./afx-cli install afx-pack-qa"
    fi
}

pack_update_all() {
    echo -e "${BLUE}Updating installed packs...${NC}"
    echo ""

    local index_ref
    index_ref=$(resolve_ref) || exit 1
    if [[ "$DRY_RUN" != "true" ]]; then
        mkdir -p "$TARGET_DIR/.afx/.cache"
        curl -sL "https://raw.githubusercontent.com/${AFX_REPO}/${index_ref}/skills.json" \
            > "$TARGET_DIR/.afx/.cache/lastIndex.json" 2>/dev/null
    fi

    local updated=0
    while IFS=: read -r pack_name pack_ref; do
        [[ -z "$pack_name" ]] && continue
        echo -e "${BLUE}Updating $pack_name (ref: $pack_ref)...${NC}"
        pack_remove "$pack_name"
        pack_install "$pack_name" "$pack_ref"
        ((updated++))
    done < <(afx_yaml_all_packs)

    if [[ "$updated" -eq 0 ]]; then
        echo "  No installed packs to update."
    fi
}

add_skill() {
    local spec="$1"
    local repo="${spec%%:*}"
    local full_path="${spec#*:}"
    local skill_name=$(basename "$full_path")
    local base_path="$(dirname "$full_path")/"

    echo -e "${BLUE}Installing skill '$skill_name' from $repo...${NC}"

    local temp
    temp=$(download_items "$repo" "main" "$base_path" "$skill_name")

    local item_dir="$temp/${base_path}${skill_name}"
    if [[ ! -d "$item_dir" ]]; then
        echo -e "${RED}Error: Skill '$skill_name' not found in $repo${NC}"
        rm -rf "$temp"
        exit 1
    fi

    local type
    type=$(detect_type "$item_dir" "$repo")

    if [[ "$DRY_RUN" != "true" ]]; then
        route_item "$item_dir" "$skill_name" "$type" "custom"
        afx_yaml_add_skill "$skill_name" "custom" "custom" "$type"
        skill_sync "$skill_name" "custom" "$type"
    fi

    rm -rf "$temp"
    echo -e "${GREEN}Skill '$skill_name' installed from $repo.${NC}"
}

