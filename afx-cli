        echo ""
        echo -e "${YELLOW}AFX is already installed in this project.${NC}"
        echo -e "  Use ${BOLD}--update${NC} to update, or ${BOLD}--force${NC} to overwrite."
        echo ""
        confirm=""
        read -r -p "Continue anyway? [y/N] " confirm < /dev/tty 2>/dev/null || confirm="y"
        if [[ ! "$confirm" =~ ^[Yy] ]]; then
            echo "Aborted."
