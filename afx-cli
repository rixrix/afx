    if [ ! -d "$TARGET_DIR/docs/adr" ]; then INSTALLED+=("docs/adr/ directory"); fi
    if [ ! -d "$TARGET_DIR/docs/research" ]; then INSTALLED+=("docs/research/ directory"); fi
}

