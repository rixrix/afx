step_skills() {
    echo -e "${BLUE}Syncing skills to .agents/skills/ (+ .claude/skills/ if Claude enabled)...${NC}"

    local canonical_root="$TARGET_DIR/.afx/skills"

    # Collect configured packs
    local configured_packs=()
    while IFS=: read -r pack_name pack_ref; do
        [[ -z "$pack_name" ]] && continue
        configured_packs+=("$pack_name:$pack_ref")
    done < <(afx_yaml_all_packs)

    # No packs configured — install defaults (fresh install or v1 upgrade)
    if [[ ${#configured_packs[@]} -eq 0 ]]; then
        echo -e "  ${CYAN}No packs configured — installing defaults...${NC}"
        for default_pack in "${DEFAULT_PACKS[@]}"; do
            pack_install "$default_pack"
        done
    else
        # Re-install any packs whose category dir is missing from the canonical store
        for entry in "${configured_packs[@]}"; do
            local pack_name="${entry%%:*}"
            local pack_ref="${entry#*:}"
            local category
            category=$(category_from_pack "$pack_name")
            if [ ! -d "$canonical_root/$category" ]; then
                echo -e "  ${CYAN}Installing pack '$pack_name' into canonical store...${NC}"
                pack_install "$pack_name" "$pack_ref"
            fi
        done
    fi

    # Sync all canonical skills to .agents/skills/ (+ .claude/skills/ if Claude enabled)
    if [ ! -d "$canonical_root" ]; then
        echo -e "${DIM}  No skills to sync.${NC}"
        return
    fi

    local synced=0
    for category_dir in "$canonical_root"/*/; do
        [ -d "$category_dir" ] || continue
        local category=$(basename "$category_dir")
        for skill_dir in "$category_dir"*/; do
            [ -d "$skill_dir" ] || continue
            local skill_name=$(basename "$skill_dir")
            skill_sync "$skill_name" "$category"
            ((synced++))
