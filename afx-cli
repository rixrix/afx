    cmd_skill_toggle "$SKILL_DISABLE" "off"
fi

if [[ -n "$SKILL_ENABLE" ]]; then
    PACK_OPERATION=true
    cmd_skill_toggle "$SKILL_ENABLE" "on"
fi

if [[ "$UPDATE_MODE" == "true" && "$UPDATE_PACKS" == "true" ]]; then
